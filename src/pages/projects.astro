---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="Technical repositories and data models." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects & Portfolio</h1>
			<p>A collection of technical repositories, data models, and live systems architectures.</p>
			<hr />
			
			<h3>Civic Tech & Predictive Modelling</h3>
			<p><strong>National Voter Opportunity Map & Profiling</strong><br/>
			<em>Data Analysis, Geospatial Mapping, Predictive Modelling</em></p>
			<p>
				Developing bespoke, data-driven tools to identify and profile receptive audiences for grassroots organisations. This project involves the complex analysis of geospatial, demographic, and electoral data to create national voter opportunity maps and detailed profile documents. These systems are designed to be integrated into comprehensive campaign suites for predictive forecasting and route planning.
			</p>

			<br />

			<h3>Frontier Systems</h3>
			<p><strong>[Project Name / Space Tech Repo]</strong><br/>
			<em>Python, C++, Systems Architecture</em></p>
			<p>
				Exploring the data architecture required for orbital and lunar infrastructure. <em>(Note: Link to specific GitHub repo when ready)</em>.
			</p>
		</main>
		<Footer />
	</body>
</html>