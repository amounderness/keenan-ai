---
import BaseHead from '../../components/BaseHead.astro';
import ThemeSidebar from '../../components/ThemeSidebar.astro';
import ModuleCard from '../../components/ModuleCard.astro';
import { THEMES, getInitialModules } from '../../data/modules';
import '../../styles/global.css';

const initialModules = getInitialModules(); 
---

<!doctype html>
<html lang="en-gb">
	<head>
		<BaseHead title="Planner Workshop" description="Bright and modular planning." />
		<style>
			:root { --sidebar-bg: #fdfdfd; --main-bg: #f8fafc; }
			body { background: var(--main-bg); color: #1e293b; }
			.workshop-shell { display: grid; grid-template-columns: 280px 1fr; min-height: 100vh; }
			aside { background: var(--sidebar-bg); border-right: 1px solid #f1f5f9; padding: 2.5rem; }
			main { padding: 3.5rem; max-width: 1200px; }
			header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
			h1 { font-size: 2.25rem; font-weight: 800; letter-spacing: -0.02em; color: #0f172a; margin: 0; }
			.subtitle { color: #64748b; margin-top: 0.5rem; }
			.module-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }
			.add-card {
				border: 2px dashed #e2e8f0; background: transparent; border-radius: 12px;
				display: flex; flex-direction: column; align-items: center; justify-content: center;
				min-height: 160px; cursor: pointer; transition: all 0.2s; color: #94a3b8;
			}
			.add-card:hover { border-color: #3b82f6; background: #eff6ff; color: #3b82f6; }
		</style>
	</head>
	<body>
		<div class="workshop-shell">
			<aside>
				<h2 style="font-size: 0.75rem; text-transform: uppercase; color: #94a3b8; letter-spacing: 0.05em; margin-bottom: 2rem;">Aspects of Life</h2>
				<ThemeSidebar />
			</aside>
			<main>
				<header>
					<div>
						<h1>Planner Workshop</h1>
						<p class="subtitle">Design the modules that make up your week.</p>
					</div>
					<button class="primary-btn" id="save-config">Save All Changes</button>
				</header>

				<div class="module-grid" id="main-grid">
					{initialModules.map(mod => {
						const theme = THEMES.find(t => t.id === mod.themeId);
						return <ModuleCard module={mod} theme={theme} />
					})}
					<button class="add-card" id="open-creator">
						<span style="font-size: 1.5rem; font-weight: 300;">+</span>
						<span style="font-size: 0.85rem; font-weight: 600; margin-top: 0.5rem;">New Module</span>
					</button>
				</div>
			</main>
		</div>

		<script>
			// Persistence Logic
			let userModules = JSON.parse(localStorage.getItem('user_modules') || '[]');

			// Save to localStorage when triggered
			document.getElementById('save-config')?.addEventListener('click', () => {
				localStorage.setItem('user_modules', JSON.stringify(userModules));
				alert('Workspace saved locally!');
			});

			// Theme Filtering Logic
			const themeButtons = document.querySelectorAll('.theme-btn');
			themeButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const selectedTheme = btn.getAttribute('data-theme');
					document.querySelectorAll('.module-card').forEach(card => {
						const cardTheme = card.getAttribute('data-theme');
						(card as HTMLElement).style.display = (!selectedTheme || cardTheme === selectedTheme) ? 'flex' : 'none';
					});
				});
			});
		</script>
	</body>
</html>