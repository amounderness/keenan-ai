---
import BaseHead from '../../components/BaseHead.astro';
import ThemeSidebar from '../../components/ThemeSidebar.astro';
import ModuleCard from '../../components/ModuleCard.astro';
import { THEMES, getInitialModules } from '../../data/modules';
import '../../styles/global.css';

const initialModules = getInitialModules(); 
---

<!doctype html>
<html lang="en-gb">
	<head>
		<BaseHead title="Planner Workshop" description="Bright and modular planning." />
		<style>
			:root { 
				--sidebar-bg: #fdfdfd; 
				--main-bg: #f8fafc; 
				--primary-blue: #3b82f6;
			}
			body { background: var(--main-bg); color: #1e293b; font-family: 'Atkinson Hyperlegible', sans-serif; }
			
			.workshop-shell { display: grid; grid-template-columns: 280px 1fr; min-height: 100vh; }
			
			aside { background: var(--sidebar-bg); border-right: 1px solid #f1f5f9; padding: 2.5rem; }
			
			main { padding: 3.5rem; max-width: 1200px; margin: 0 auto; width: 100%; }
			
			header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
			
			h1 { font-size: 2.25rem; font-weight: 800; letter-spacing: -0.02em; color: #0f172a; margin: 0; }
			.subtitle { color: #64748b; margin-top: 0.5rem; }

			.module-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }

			.primary-btn {
				background: var(--primary-blue); color: white; border: none; padding: 0.75rem 1.5rem;
				border-radius: 8px; font-weight: 700; cursor: pointer; transition: opacity 0.2s;
			}
			.primary-btn:hover { opacity: 0.9; }

			.add-card {
				border: 2px dashed #e2e8f0; background: transparent; border-radius: 12px;
				display: flex; flex-direction: column; align-items: center; justify-content: center;
				min-height: 180px; cursor: pointer; transition: all 0.2s; color: #94a3b8;
			}
			.add-card:hover { border-color: var(--primary-blue); background: #eff6ff; color: var(--primary-blue); }

			/* Modal Styles */
			.modal-overlay {
				display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.4);
				backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center;
			}
			.modal-content {
				background: white; width: 90%; max-width: 450px; padding: 2rem;
				border-radius: 16px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
			}
			.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
			.modal-header h2 { font-size: 1.25rem; font-weight: 700; margin: 0; }
			#close-modal { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #94a3b8; }
			
			.form-group { margin-bottom: 1.5rem; }
			.form-group label { display: block; font-size: 0.85rem; font-weight: 600; color: #64748b; margin-bottom: 0.5rem; }
			.form-group input { width: 100%; padding: 0.75rem; border: 1px solid #e2e8f0; border-radius: 8px; font-family: inherit; }
			
			.theme-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
			.theme-option {
				padding: 0.6rem; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.85rem;
				text-align: center; cursor: pointer; transition: all 0.2s; font-weight: 500;
			}
			.theme-option.selected { outline: 2px solid var(--primary-blue); font-weight: 700; }
			
			.form-footer { display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2rem; }
			.secondary-btn { background: #f1f5f9; border: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-weight: 600; cursor: pointer; }
		</style>
	</head>
	<body>
		<div class="workshop-shell">
			<aside>
				<h2 style="font-size: 0.75rem; text-transform: uppercase; color: #94a3b8; letter-spacing: 0.05em; margin-bottom: 2rem;">Aspects of Life</h2>
				<ThemeSidebar />
			</aside>

			<main>
				<header>
					<div>
						<h1>Planner Workshop</h1>
						<p class="subtitle">Design the modules that make up your week.</p>
					</div>
					<button class="primary-btn" id="save-config">Save to Cloud</button>
				</header>

				<div class="module-grid" id="main-grid">
					<!-- 1. Static Inboxes Rendered by Astro -->
					{initialModules.map(mod => {
						const theme = THEMES.find(t => t.id === mod.themeId);
						return <ModuleCard module={mod} theme={theme} />
					})}

					<!-- 2. Custom Modules will be injected here by JS -->
					
					<button class="add-card" id="open-creator">
						<span style="font-size: 2rem; font-weight: 300;">+</span>
						<span style="font-size: 0.9rem; font-weight: 600; margin-top: 0.5rem;">New Module</span>
					</button>
				</div>
			</main>
		</div>

		<!-- Modal UI -->
		<div id="module-modal" class="modal-overlay">
			<div class="modal-content">
				<div class="modal-header">
					<h2>Create New Module</h2>
					<button id="close-modal">&times;</button>
				</div>
				
				<div class="form-group">
					<label>Module Name</label>
					<input type="text" id="new-module-name" placeholder="e.g. Portfolio Development" />
				</div>

				<div class="form-group">
					<label>Aspect of Life (Theme)</label>
					<div class="theme-grid" id="modal-theme-grid">
						<!-- JS will inject THEMES here -->
					</div>
				</div>

				<div class="form-footer">
					<button class="secondary-btn" id="cancel-btn">Cancel</button>
					<button class="primary-btn" id="confirm-create">Create Module</button>
				</div>
			</div>
		</div>

		<script define:vars={{ THEMES }}>
			// 1. STATE MANAGEMENT
			let selectedThemeId = 'University';
			const modal = document.getElementById('module-modal');
			const themeGrid = document.getElementById('modal-theme-grid');
			const mainGrid = document.getElementById('main-grid');

			// 2. MODAL THEME INJECTION
			THEMES.forEach(theme => {
				const div = document.createElement('div');
				div.className = 'theme-option';
				div.style.backgroundColor = theme.color;
				div.style.color = theme.textColor;
				div.innerText = theme.label;
				
				if (theme.id === selectedThemeId) div.classList.add('selected');

				div.onclick = () => {
					document.querySelectorAll('.theme-option').forEach(el => el.classList.remove('selected'));
					div.classList.add('selected');
					selectedThemeId = theme.id;
				};
				themeGrid.appendChild(div);
			});

			// 3. OPEN/CLOSE CONTROLS
			document.getElementById('open-creator').onclick = () => modal.style.display = 'flex';
			document.getElementById('close-modal').onclick = () => modal.style.display = 'none';
			document.getElementById('cancel-btn').onclick = () => modal.style.display = 'none';

			// 4. CREATE MODULE LOGIC[cite: 2]
			document.getElementById('confirm-create').onclick = () => {
				const nameInput = document.getElementById('new-module-name');
				const name = nameInput.value;
				
				if (!name) return alert('Please name your module');

				const newModule = {
					id: `custom-${Date.now()}`,
					themeId: selectedThemeId,
					name: name,
					suggestedDuration: 60,
					tasks: []
				};

				const userModules = JSON.parse(localStorage.getItem('user_modules') || '[]');
				userModules.push(newModule);
				localStorage.setItem('user_modules', JSON.stringify(userModules));

				// Reset and close
				nameInput.value = '';
				modal.style.display = 'none';
				
				// Re-render to show new module immediately
				window.location.reload(); 
			};

			// 5. THEME FILTERING[cite: 2]
			const themeButtons = document.querySelectorAll('.theme-btn');
			themeButtons.forEach(btn => {
				btn.addEventListener('click', () => {
					const themeId = btn.getAttribute('data-theme');
					const cards = document.querySelectorAll('.module-card');
					
					cards.forEach(card => {
						const cardTheme = card.getAttribute('data-theme');
						if (!themeId || cardTheme === themeId) {
							card.style.display = 'flex';
						} else {
							card.style.display = 'none';
						}
					});
				});
			});

			// 6. RENDER CUSTOM MODULES FROM LOCALSTORAGE
			// Since Astro renders static items, we must manually append the custom ones on load
			const customModules = JSON.parse(localStorage.getItem('user_modules') || '[]');
			customModules.forEach(mod => {
				const theme = THEMES.find(t => t.id === mod.themeId);
				const cardHtml = `
					<div class="module-card" data-theme="${mod.themeId}" style="--bg: ${theme.color}; --text: ${theme.textColor}">
						<div class="card-header">
							<span class="theme-tag" style="background: ${theme.color}; color: ${theme.textColor}">${theme.label}</span>
						</div>
						<h3 style="margin: 0.75rem 0; font-size: 1.1rem; font-weight: 600;">${mod.name}</h3>
						<div style="font-size: 0.85rem; color: #64748b;">${mod.tasks.length} tasks</div>
						<div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center;">
							<span style="font-size: 0.75rem; color: #94a3b8; background: #f8fafc; padding: 2px 8px; border-radius: 4px;">${mod.suggestedDuration}m</span>
							<button class="add-task-btn" style="border: 1px solid #e2e8f0; background: white; width: 24px; height: 24px; border-radius: 6px; cursor: pointer; color: #64748b;">+</button>
						</div>
					</div>
				`;
				// Insert before the "Add New" button
				const addButton = document.getElementById('open-creator');
				addButton.insertAdjacentHTML('beforebegin', cardHtml);
			});
		</script>
	</body>
</html>