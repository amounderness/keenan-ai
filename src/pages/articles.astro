---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Articles | ${SITE_TITLE}`} description="Algorithms & Activism" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Algorithms & Activism</h1>
			<p>
				Where data science meets grassroots politics. This is my public broadcast focusing on the intersection of modern technology and civic engagement.
			</p>
			<p>
				<a href="https://keenanclough.substack.com" target="_blank" style="display: inline-block; padding: 10px 20px; background-color: var(--accent); color: white; text-decoration: none; border-radius: 5px; font-weight: bold; margin-top: 10px;">
					Read the latest on Substack
				</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
