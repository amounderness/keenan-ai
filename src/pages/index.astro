---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Human Ambition x Autonomous Systems</h1>
			<p>
				Hi, I'm Keenan Clough. I sit at the intersection of public policy, digital operations, and frontier data science.
			</p>
			<p>
				My goal is to design the systems that allow for autonomy, resilience, and ethical governance in high-stakes environments—whether that is improving public services on Earth or architecting infrastructure for the frontiers of space.
			</p>
			
			<hr />
			
			<h3>The Hub</h3>
			<ul>
				<li><strong><a href="/articles">Articles:</a></strong> My public broadcasts on data science and grassroots politics.</li>
				<li><strong><a href="/notes">Lab Notes:</a></strong> Technical exploration, code snippets, and systems architecture research.</li>
				<li><strong><a href="/projects">Projects:</a></strong> Live demos, GitHub repositories, and data dashboards.</li>
			</ul>

			<br />
			
			<div style="background-color: var(--gray-light); padding: 2em; border-radius: 8px; border-left: 4px solid var(--accent); margin-top: 2em;">
				<h3 style="margin-top: 0;">Initiate Contact</h3>
				<p style="color: var(--gray-dark); margin-bottom: 1.5em;">
					I am actively seeking technical collaborations, research opportunities, and roles where public policy collides with data science.
				</p>
				<a href="mailto:keenanrclough@gmail.com" style="display: inline-block; padding: 10px 20px; background-color: var(--black); color: white; text-decoration: none; border-radius: 5px; font-weight: bold; transition: background-color 0.2s ease;">
					Email Me
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
