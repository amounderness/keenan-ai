---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
    <h1>Human Ambition x Autonomous Systems</h1>
    <p>
        Hi, I'm Keenan Clough. I sit at the intersection of public policy, digital operations, and frontier data science.
    </p>
    <p>
        My goal is to design the systems that allow for autonomy, resilience, and ethical governance in high-stakes environments—whether that is improving public services on Earth or architecting infrastructure for the frontiers of space.
    </p>
    <ul>
        <li><strong>Currently exploring:</strong> Autonomous Agentic Workflows in Lunar Logistics.</li>
        <li><strong>Building with:</strong> Machine Learning, Python, C++, and SQL.</li>
    </ul>
</main>
		<Footer />
	</body>
</html>
