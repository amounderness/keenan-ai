---
import type { Module } from '../data/modules';
const { module, themeColor } = Astro.props;
---
<div class="module-card" style={`--accent: ${themeColor}`}>
  <div class="header">
    <h3>{module.name}</h3>
    {module.isInbox && <span class="badge">Inbox</span>}
  </div>
  <p class="task-count">{module.tasks.length} active tasks</p>
  <div class="footer">
    <span>{module.suggestedDuration}m</span>
  </div>
</div>

<style>
  .module-card {
    background: #1a1a1a; border-left: 4px solid var(--accent);
    padding: 1.25rem; border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer; display: flex; flex-direction: column; gap: 8px;
  }
  .module-card:hover { 
    transform: translateY(-4px); 
    box-shadow: 0 4px 20px rgba(0,0,0,0.3), 0 0 10px var(--accent);
  }
  .header { display: flex; justify-content: space-between; align-items: center; }
  h3 { margin: 0; font-size: 1.1rem; color: #fff; }
  .badge { font-size: 0.7rem; background: var(--accent); color: #000; padding: 2px 6px; border-radius: 4px; font-weight: bold; }
  .task-count { font-size: 0.85rem; color: #888; margin: 0; }
  .footer { margin-top: auto; font-size: 0.75rem; color: var(--accent); font-weight: bold; }
</style>