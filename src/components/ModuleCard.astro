---
import type { Module } from '../data/modules';
const { module, themeColor } = Astro.props;
---
<div class="module-card" data-theme={module.themeId} style={`--accent: ${themeColor}`}>
  <div class="header">
    <h3>{module.name}</h3>
    {module.isInbox && <span class="badge">Inbox</span>}
  </div>
  
  <div class="task-list">
    {module.tasks.length > 0 ? (
      module.tasks.slice(0, 3).map(task => (
        <div class="task-item">
          <input type="checkbox" disabled />
          <span>{task.description}</span>
        </div>
      ))
    ) : (
      <p class="empty-msg">No tasks yet.</p>
    )}
    {module.tasks.length > 3 && <p class="more-count">+{module.tasks.length - 3} more</p>}
  </div>

  <div class="quick-add">
    <input type="text" placeholder="Add task..." />
  </div>

  <div class="footer">
    <span class="duration">{module.suggestedDuration}m</span>
    <button class="edit-btn">Edit Module</button>
  </div>
</div>

<style>
  .module-card {
    background: #1a1a1a; border-top: 4px solid var(--accent);
    padding: 1.25rem; border-radius: 8px; display: flex; flex-direction: column; gap: 1rem;
    transition: all 0.2s ease;
  }
  .module-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
  
  h3 { margin: 0; font-size: 1rem; letter-spacing: -0.01em; color: #fff; }
  .badge { font-size: 0.65rem; background: var(--accent); color: #000; padding: 2px 6px; border-radius: 3px; font-weight: 800; text-transform: uppercase; }
  
  .task-list { display: flex; flex-direction: column; gap: 6px; min-height: 80px; }
  .task-item { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: #ccc; }
  .empty-msg { font-size: 0.8rem; color: #555; font-style: italic; }
  
  .quick-add input {
    width: 100%; background: #000; border: 1px solid #333; color: #fff;
    padding: 6px 10px; border-radius: 4px; font-size: 0.8rem;
  }
  .quick-add input:focus { outline: none; border-color: var(--accent); }

  .footer { display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem; }
  .duration { font-size: 0.75rem; color: var(--accent); font-weight: bold; }
  .edit-btn { background: transparent; border: 1px solid #444; color: #aaa; font-size: 0.7rem; padding: 4px 8px; border-radius: 4px; cursor: pointer; }
  .edit-btn:hover { color: #fff; border-color: #666; }
</style>